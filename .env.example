# =============================================================================
# signal-cli-gateway Environment Configuration
# =============================================================================
# Copy this file to .env and adjust for your setup.
#
# Security Modes:
#   loopback        - signal-cli on 127.0.0.1:8080, no proxy (default)
#   loopback-proxy  - signal-cli on 127.0.0.1:8080 + secured-signal-api on
#                     127.0.0.1:8880 with auth
#   exposed-proxy   - signal-cli on 127.0.0.1:8080 + secured-signal-api on
#                     0.0.0.0:8880 with auth (WAN-accessible)
#   unix            - signal-cli on UNIX socket + socat TCP bridge
# =============================================================================

# -- Required --
SIGNAL_ACCOUNT=+123****7890

# -- Security (choose one) --
SECURITY_MODE=loopback-proxy

# -- Proxy auth (for loopback-proxy / exposed-proxy) --
# SECURITY_PROXY_TOKEN=changeme
# SECURITY_PROXY_ALLOWED_IPS=127.0.0.1,172.0.0.0/8,10.0.0.0/8

# -- Ports --
# PROXY_PORT=8880
# SIGNAL_CLI_PORT=8080

# -- signal-cli daemon options --
# SIGNAL_CLI_TRUST_NEW_IDENTITIES=on-first-use